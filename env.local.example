# Rename this file to .env.local before running locally.
# NEVER commit .env.local to version control.

# ── Clinic contact details ───────────────────────────────────────────────────
NEXT_PUBLIC_CLINIC_PHONE=+919876543210
NEXT_PUBLIC_CLINIC_WHATSAPP=+919876543210

# ── Site / domain ─────────────────────────────────────────────────────────────
# Used for canonical URLs, Open Graph, and JSON-LD schema
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_DOMAIN=yourdomain.com

# ── Google Maps ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Google Sheets appointment logging ────────────────────────────────────────
# Deploy an Apps Script Web App and paste its URL here.
# See src/lib/googleSheets.js for setup instructions.
NEXT_PUBLIC_GOOGLE_SHEETS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Google Analytics 4 ───────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Contact form endpoint (optional) ─────────────────────────────────────────
# Wire up to Resend, EmailJS, Formspree, or your own API route.
NEXT_PUBLIC_CONTACT_ENDPOINT=
